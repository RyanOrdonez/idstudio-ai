# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Canva API Configuration (for mood boards)
# Get these from https://www.canva.com/developers/
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here

# AI Image Generation (DALL-E or Stable Diffusion)
# For DALL-E, use your OpenAI API key above
# For Stable Diffusion, get API key from https://stability.ai/
STABILITY_API_KEY=your_stability_api_key_here

# Email Integration (optional)
# For Gmail API integration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# File Storage Configuration
# Supabase Storage bucket name for file uploads
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=idstudio-files

# Stripe Configuration
# Get these from your Stripe dashboard at https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (get these from your Stripe Dashboard)
STRIPE_STARTER_PLAN_PRICE_ID=price_your_starter_plan_price_id_here
STRIPE_PRO_PLAN_PRICE_ID=price_your_pro_plan_price_id_here
NEXT_PUBLIC_STRIPE_STARTER_PLAN_PRICE_ID=price_your_starter_plan_price_id_here
NEXT_PUBLIC_STRIPE_PRO_PLAN_PRICE_ID=price_your_pro_plan_price_id_here

# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Add your actual Supabase URL and anon key (required for app to run)
# 3. Add your OpenAI API key (required for AI assistant)
# 4. Add your Stripe keys (required for subscriptions)
# 5. Add Canva credentials (optional, for mood board integration)
# 6. Add Stability AI key (optional, for AI image generation)
# 7. Add Google credentials (optional, for Gmail integration)
# 8. The .env.local file is gitignored for security
