// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")       // Supabase pooler URL (used at runtime)
  directUrl  = env("DIRECT_URL")         // Supabase direct URL (used for migrations)
  extensions = [pgvector(map: "vector"), pg_trgm, citext]
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  manager
  designer
  client
}

enum ProjectStatus {
  active
  on_hold
  completed
  archived
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum PhaseKind {
  discovery
  design
  procurement
  install
  closeout
}

enum AssetType {
  image
  floor_plan
  spec_sheet
  render
  document
}

enum AIInsightType {
  design_suggestion
  schedule_risk
  budget_alert
  style_match
}

enum BudgetCategory {
  furniture
  lighting
  flooring
  textiles
  accessories
  labor
  other
}

enum GeneratedProposalStatus {
  generating
  ready
  sent
  failed
}

enum ProposalTemplate {
  classic
  modern
  minimal
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH & MULTI-TENANCY CORE
// ─────────────────────────────────────────────────────────────────────────────

/// A firm / organisation — the top-level isolation boundary.
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // used for subdomain routing
  logoUrl     String?
  plan        String   @default("starter") // starter | pro | enterprise
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  projects     Project[]
  vendors      Vendor[]
  clients      Client[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

/// A person who belongs to a tenant with a specific role.
model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  role          UserRole  @default(designer)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  assignedTasks Task[]     @relation("TaskAssignee")
  createdTasks  Task[]     @relation("TaskCreator")
  auditLogs     AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

/// OAuth account linked to a user (NextAuth adapter compatible).
model Account {
  id                String  @id @default(cuid())
  userId            String
  tenantId          String
  type              String  // "oauth" | "email" | "credentials"
  provider          String  // "google" | "email"
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([tenantId])
  @@map("accounts")
}

/// NextAuth session record.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  tenantId     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

/// Email magic-link verification tokens (NextAuth adapter).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Long-lived API keys for Tauri desktop and programmatic access.
model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  name        String                          // e.g. "Tauri Desktop — MacBook Pro"
  keyHash     String    @unique               // bcrypt hash of the raw key
  keyPrefix   String                          // first 8 chars for display, e.g. "ids_live"
  lastUsedAt  DateTime?
  expiresAt   DateTime?                       // null = never expires
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([keyPrefix])
  @@map("api_keys")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  tenantId    String
  clientId    String?
  title       String
  description String?       @db.Text
  status      ProjectStatus @default(active)
  startDate   DateTime?
  targetDate  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client             Client?              @relation(fields: [clientId], references: [id])
  phases             Phase[]
  budget             Budget?
  assets             Asset[]
  insights           AIInsight[]
  proposals          ProposalApproval[]
  generatedProposals GeneratedProposal[]

  @@index([tenantId])
  @@index([clientId])
  @@map("projects")
}

model Phase {
  id        String    @id @default(cuid())
  tenantId  String
  projectId String
  kind      PhaseKind
  title     String
  order     Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([tenantId])
  @@index([projectId])
  @@map("phases")
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  phaseId     String
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  assigneeId  String?
  creatorId   String
  dueDate     DateTime?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  phase    Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])

  @@index([tenantId])
  @@index([phaseId])
  @@index([assigneeId])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUDGET & VENDOR
// ─────────────────────────────────────────────────────────────────────────────

model Budget {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String   @unique
  total     Decimal  @db.Decimal(14, 2) @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems BudgetLineItem[]

  @@index([tenantId])
  @@map("budgets")
}

model BudgetLineItem {
  id         String         @id @default(cuid())
  tenantId   String
  budgetId   String
  vendorId   String?
  category   BudgetCategory
  description String
  estimate   Decimal        @db.Decimal(14, 2) @default(0)
  actual     Decimal        @db.Decimal(14, 2) @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  budget Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@index([tenantId])
  @@index([budgetId])
  @@map("budget_line_items")
}

model Vendor {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  website     String?
  contactName String?
  contactEmail String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems BudgetLineItem[]

  @@index([tenantId])
  @@map("vendors")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENTS (portal access)
// ─────────────────────────────────────────────────────────────────────────────

enum ProposalStatus {
  pending_approval
  approved
  revision_requested
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  notes     String?  @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects           Project[]
  portalSessions     ClientPortalSession[]
  proposals          ProposalApproval[]
  generatedProposals GeneratedProposal[]

  @@index([tenantId])
  @@map("clients")
}

/// One-time magic link token for client portal sign-in.
model ClientPortalSession {
  id         String    @id @default(cuid())
  tenantId   String
  clientId   String
  email      String    // email the link was sent to
  token      String    @unique  // cryptographically random
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@map("client_portal_sessions")
}

/// Client approval/rejection of design proposals (assets of type render/document).
model ProposalApproval {
  id        String         @id @default(cuid())
  tenantId  String
  projectId String
  assetId   String
  clientId  String
  status    ProposalStatus @default(pending_approval)
  comment   String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([assetId, clientId])
  @@index([tenantId])
  @@index([projectId])
  @@map("proposal_approvals")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSETS & AI
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id        String    @id @default(cuid())
  tenantId  String
  projectId String
  type      AssetType
  filename  String
  mimeType  String
  url       String    // S3 / presigned CDN URL
  sizeBytes Int
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  embedding Unsupported("vector(1536)")?

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  insights           AIInsight[]
  proposals          ProposalApproval[]
  generatedProposals GeneratedProposal[]

  @@index([tenantId])
  @@index([projectId])
  @@map("assets")
}

/// AI-generated design proposal document (PDF) for a project.
model GeneratedProposal {
  id           String                  @id @default(cuid())
  tenantId     String
  projectId    String
  clientId     String?
  /// Linked Asset record (PDF document) once generation is complete
  assetId      String?
  template     ProposalTemplate        @default(classic)
  status       GeneratedProposalStatus @default(generating)
  /// Monotonically-increasing version number; incremented on each revision
  version      Int                     @default(1)
  /// Structured proposal JSON produced by Claude
  proposalData Json?
  /// Direct CDN URL to the rendered PDF (mirrors Asset.url for convenience)
  pdfUrl       String?
  sentAt       DateTime?
  /// Designer note passed to Claude when requesting a revision
  feedbackNote String?                 @db.Text
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id])
  client  Client? @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@map("generated_proposals")
}

model AIInsight {
  id        String        @id @default(cuid())
  tenantId  String
  projectId String
  assetId   String?
  type      AIInsightType
  body      String        @db.Text
  metadata  Json?
  createdAt DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@map("ai_insights")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String   // e.g. "project.created", "user.role_changed"
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@map("notifications")
}
